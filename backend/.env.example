# Application
NODE_ENV=development
PORT=3001

# Database type: mysql | postgres | sqlite
DB_TYPE=mysql

# MySQL / PostgreSQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=swop
DB_PASSWORD=swop_password
DB_NAME=swop_db

# SQLite (used when DB_TYPE=sqlite)
DB_SQLITE_PATH=./swop-dev.db

# JWT
JWT_ACCESS_SECRET=swop_access_secret_change_in_production_minimum_32_chars
JWT_REFRESH_SECRET=swop_refresh_secret_change_in_production_minimum_32_chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
